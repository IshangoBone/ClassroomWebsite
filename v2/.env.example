# CodeTheCurrent V2 local environment template
#
# Copy this file to .env.local for local notes/config values that should not be
# committed. The current static frontend reads Supabase browser config from
# services/supabase/config.local.js; keep the values here aligned with that file.

APP_ENV=local
APP_ORIGIN=http://127.0.0.1:4173
APP_DASHBOARD_PATH=/pages/dashboard/index.html

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_publishable_key
GOOGLE_OAUTH_ENABLED=false

# Future seed workflow placeholder. Keep false until a real seed script exists.
USE_SAMPLE_SEED_DATA=false
